{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "global-lookup"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "dialog:allow-open"
  ]
}
